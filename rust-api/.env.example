# API server
API_BIND=0.0.0.0:8080
API_KEY=replace_with_secure_api_key

# ffmpeg binary path (on Windows use full path, e.g. C:\tools\ffmpeg\bin\ffmpeg.exe)
FFMPEG_BIN=ffmpeg

# MediaMTX RTSP publish base. Streams publish to {base}/{printer_id}
MEDIAMTX_RTSP_PUBLISH=rtsp://127.0.0.1:8554

# URL returned by API for browser playback. Use {id} placeholder.
WEBRTC_URL_TEMPLATE=http://127.0.0.1:8889/{id}/

# Capacity guardrail for concurrent printer streams
MAX_CONCURRENT_STREAMS=25

# Optional: JSON file with printer definitions loaded on startup
# PRINTERS_FILE=printers.json
